RewriteEngine On
RewriteBase /

# 1. Rewrite /api requests to index.php
RewriteRule ^api(.*)$ index.php [L,QSA,END]

# 2. Rewrite empty path to /frontend/index.html
RewriteRule ^$ /frontend/index.html [L,END]

# 3. Check if the requested resource exists in /frontend
RewriteCond %{DOCUMENT_ROOT}/frontend%{REQUEST_URI} -f
RewriteRule ^(.*)$ /frontend/$1 [L,END]

# 4. If not found, rewrite to /frontend/index.html
RewriteRule ^(.*)$ /frontend/index.html [L,END]
